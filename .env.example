# ─────────────────────────────────────────────────────────────
# Resend — envio de e-mail do formulário de contato (/contato)
# ─────────────────────────────────────────────────────────────

# Chave de API do Resend. Crie em: https://resend.com/api-keys
# Local: coloque no arquivo .env.local (não versionado).
# Produção: cadastre como Environment Variable no painel da Vercel.
RESEND_API_KEY=

# Remetente do e-mail (opcional).
# Enquanto o domínio NÃO estiver verificado no Resend, deixe em branco
# (usa o sandbox onboarding@resend.dev, que só entrega para o e-mail
# dono da conta Resend — bom para teste).
# Depois de verificar legitimusgreentech.com.br no Resend, defina:
#   RESEND_FROM="Legitimus GreenTech <contato@legitimusgreentech.com.br>"
RESEND_FROM=
